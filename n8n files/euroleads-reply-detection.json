              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ { \"fromEmail\": $json.from.value[0].address, \"subject\": $json.subject, \"body\": $json.text || $json.snippet } }}",
        "options": {}
      },
      "id": "2f0a1b1a-0002-4a1a-9a1a-000000000002",
      "name": "Notify EuroLeads",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [460, 300]
    }
  ],
  "connections": {
    "Gmail Trigger": {
      "main": [
        [
          {
            "node": "Notify EuroLeads",
            "type": "main",
            "index": 0
