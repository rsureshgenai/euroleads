# ── Supabase ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Groq API (lead extraction & classification) ─────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.3-70b-versatile

# ── n8n Webhooks (outbound, app -> n8n) ─────────────────
N8N_SEARCH_WEBHOOK_URL=https://your-n8n-instance.com/webhook/euroleads-search
N8N_SEND_EMAIL_WEBHOOK_URL=https://your-n8n-instance.com/webhook/euroleads-send-email

# ── Inbound webhook security (n8n -> app) ───────────────
# n8n must send this value in the "x-webhook-secret" header
WEBHOOK_SHARED_SECRET=change-this-to-a-long-random-string

# ── App ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Brochure storage (Supabase Storage bucket name) ─────
NEXT_PUBLIC_BROCHURE_BUCKET=brochures
